{
    "imports": {
        "@deno/vite-plugin": "npm:@deno/vite-plugin@2.0.2",
        "@oak/oak": "jsr:@oak/oak@^17.2.0",
        "@std/cli/parse-args": "jsr:@std/cli@1.0.21/parse-args",
        "@std/log": "jsr:@std/log@^0.224.14",
        "@std/crypto": "jsr:@std/crypto@^1.0.5",
        "@std/http/file-server": "jsr:@std/http@^1.0.12/file-server",
        "@std/path": "jsr:@std/path@^1.0.8",
        "@std/testing": "jsr:@std/testing@^1.0.17",
        "@std/assert": "jsr:@std/assert@^1.0.19",
        "@std/testing/bdd": "jsr:@std/testing@^0.225.3/bdd",
        "@supabase/supabase-js": "npm:@supabase/supabase-js@^2.110.0",
        "@sveltejs/vite-plugin-svelte": "npm:@sveltejs/vite-plugin-svelte@^4.0.4",
        "esm-env": "npm:esm-env@1.2.2",
        "lodash": "npm:lodash@^4.18.1",
        "nunjucks": "npm:nunjucks@^3.2.4",
        "superoak": "https://deno.land/x/superoak@5.0.0/mod.ts",
        "svelte": "npm:svelte@^5.55.2",
        "vite": "npm:vite@^5.4.21"
    },
    "fmt": {
        "exclude": [".github", "*.md"],
        "indentWidth": 4,
        "useTabs": false,
        "semiColons": true,
        "singleQuote": false,
        "spaceSurroundingProperties": true,
        "operatorPosition": "maintain",
        "lineWidth": 125,
        "newLineKind": "crlf",
        "proseWrap": "always",
        "trailingCommas": "never",
        "typeLiteral.separatorKind": "comma",
        "quoteProps": "consistent"
    },
    "test": {
        "include": ["tests/**/*.test.ts", "tests/integration/**/*.test.ts"],
        "permissions": {
            "net": true,
            "read": true,
            "env": true,
            "import": [
                "deno.land",
                "jspm.dev",
                "jsr.io"
            ]
        }
    },
    "permissions": {
        "server": {
            "net": true,
            "read": [
                "static",
                "templates"
            ],
            "env": [
                "FIREBASE_ITK",
                "FIREBASE_CLIENT_VERSION",
                "FIREBASE_CLIENT_TOKEN",
                "ORIGIN",
                "GQL_ENDPOINT",
                "USER_AGENT",
                "OEMBED_PROTOCOL",
                "LISTEN",
                "METRICS",
                "METRICS_KEY",
                "LOG_LEVEL",
                "ANALYTICS",
                "SUPABASE_URL",
                "SUPABASE_KEY",
                "INGEST_SECRET"
            ]
        },
        "healthcheck": {
            "net": true,
            "env": [
                "FIREBASE_ITK",
                "FIREBASE_CLIENT_VERSION",
                "FIREBASE_CLIENT_TOKEN",
                "ORIGIN",
                "GQL_ENDPOINT",
                "USER_AGENT",
                "OEMBED_PROTOCOL",
                "LISTEN",
                "METRICS",
                "METRICS_KEY",
                "LOG_LEVEL",
                "ANALYTICS",
                "SUPABASE_URL",
                "SUPABASE_KEY",
                "INGEST_SECRET"
            ]
        }
    },
    "tasks": {
        "start": "deno run --permission-set=server src/server.ts",
        "compile:server": "deno compile --permission-set=server --include static/ --include templates/",
        "compile:healthcheck": "deno compile --permission-set=healthcheck",
        "test": "deno test -P --coverage=coverage",
        "test:unit": "deno test -P tests/unit",
        "test:integration": "deno test -P tests/integration",
        "check": "deno check --allow-import src",
        "dashboard:dev": "deno run -A --node-modules-dir npm:vite dev dashboard --config dashboard/vite.config.mts",
        "dashboard:build": "deno run -A --node-modules-dir npm:vite build dashboard --config dashboard/vite.config.mts"
    }
}
